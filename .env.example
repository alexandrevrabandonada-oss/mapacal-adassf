NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# URL do app para scripts locais (ex: http://localhost:3000 ou https://mapa.com.br)
APP_BASE_URL=

# Segredo de operação cron para disparar jobs
# Endpoint secreto para schedule de Webhooks Delivery (opcional)
ALERTS_CRON_SECRET=

# User Agent opcional para requisicoes Webhook
ALERT_WEBHOOK_USER_AGENT=MapaCalcadasSF-WebhookSender/1.0

# Segredo de operação cron para disparar jobs
# Mínimo de 32 chars, use token aleatório
SNAPSHOT_CRON_SECRET=
